generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}


model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  iconName    String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  employeeNumber String?
  designation   String?
  photoUrl      String?
  dob           DateTime
  personalEmail String
  phone         String?
  startDate     DateTime
  endDate       DateTime?
  dutiesHtml    String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CompanyInfo {
  id                 String   @id @default("primary")
  companyName        String
  tagline            String
  address            String
  city               String
  region             String
  postalCode         String
  country            String
  ownerName          String   @default("Shirish Patel")
  ownerTitle         String   @default("Founder & Director")
  aboutTitle         String
  aboutBody          String
  mission            String
  globalReach        String
  contactEmail       String
  contactPhone       String
  googleMapsEmbedUrl String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  message   String
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("editor")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
